<!DOCTYPE html>
<html>
  <head>
    <title>Busy Bee</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <% unless Rails.env.test? %>
      <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <% end %>
  </head>

  <body class="min-h-screen text-busybee-700">
    <!-- Full-page background -->
    <div
      class="fixed inset-0 -z-20 bg-cover bg-center bg-no-repeat"
      style="background-image: url('<%= image_path("background.jpg") %>');"
    ></div>

    <!-- Readability overlay -->
    <div class="fixed inset-0 -z-10 bg-white/75 backdrop-blur-[1px]"></div>

    <% unless controller_name == "sessions" && action_name == "new" %>
      <header class="border-b border-slate-200/80 bg-white/85 backdrop-blur">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
          <div class="flex items-center gap-6">
            <%= link_to root_path, class: "text-xl font-bold tracking-tight text-busybee-600" do %>
              Busy Bee
            <% end %>

            <nav class="hidden md:flex items-center gap-4 text-sm font-medium text-busybee-700">
              <%= link_to "Jobs", jobs_path, class: "hover:text-busybee-700" %>
              <%= link_to "Developers", developers_path, class: "hover:text-busybee-700" %>
              <%= link_to "Clients", clients_path, class: "hover:text-busybee-700" %>
            </nav>
          </div>

          <div class="flex items-center gap-3">
            <% if logged_in? %>
              <span class="hidden text-sm text-busybee-700 sm:inline"><%= current_user.name %></span>
              <%= button_to "Logout", logout_path,
                    method: :delete,
                    class: "rounded-md bg-busybee-500 px-4 py-2 text-sm font-medium text-white hover:bg-busybee-600" %>
            <% else %>
              <%= link_to "Login", login_path,
                    class: "rounded-md bg-busybee-500 px-4 py-2 text-sm font-medium text-white hover:bg-busybee-600" %>
            <% end %>
          </div>
        </div>
      </header>
    <% end %>

    <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <% if notice %>
        <div class="mb-6 rounded-xl border border-busybee-200 bg-white/90 px-4 py-3 text-sm text-busybee-800 shadow notice">
          <%= notice %>
        </div>
      <% end %>

      <% if alert %>
        <div class="mb-6 rounded-xl border border-rose-200 bg-white/90 px-4 py-3 text-sm text-rose-800 shadow alert">
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>