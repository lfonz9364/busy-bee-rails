<div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
	<section class="lg:col-span-2">
		<div class="rounded-2xl border border-white/60 bg-white/88 p-6 shadow-xl backdrop-blur">
			<div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
				<div>
					<h1 class="text-3xl font-bold tracking-tight text-busybee-900">
						<%= @job.title %>
					</h1>

					<p class="mt-2 inline-flex rounded-full border border-busybee-200 bg-busybee-50 px-3 py-1 text-xs font-semibold text-busybee-700">
						<%= @job.status.humanize %>
					</p>
				</div>

				<div class="rounded-xl border border-busybee-200 bg-white/80 px-4 py-3 text-right shadow-sm">
					<p class="text-xs font-semibold uppercase tracking-wide text-busybee-400">Reward</p>
					<p class="mt-1 text-xl font-bold text-busybee-700">$<%= @job.reward %></p>
				</div>
			</div>

			<div class="mt-8">
				<p class="text-xs font-semibold uppercase tracking-wide text-busybee-400">Description</p>
				<p class="mt-3 text-sm leading-7 text-busybee-700 whitespace-pre-line">
					<%= @job.description %>
				</p>
			</div>
		</div>
	</section>

	<section class="lg:col-span-1">
		<div class="space-y-6">
			<div class="rounded-2xl border border-white/60 bg-white/88 p-6 shadow-xl backdrop-blur">
				<h2 class="text-lg font-semibold text-busybee-900">Job details</h2>

				<div class="mt-5 space-y-4">
					<div>
						<p class="text-xs font-semibold uppercase tracking-wide text-busybee-400">Client</p>
						<p class="mt-1 text-sm text-busybee-700">
							<%= link_to @job.client.name,
                    client_path(@job.client),
                    class: "text-busybee-700 underline decoration-busybee-200 underline-offset-2 hover:text-busybee-800" %>
						</p>
					</div>

					<div>
						<p class="text-xs font-semibold uppercase tracking-wide text-busybee-400">Developer</p>
						<p class="mt-1 text-sm text-busybee-700">
							<% if @job.developer.present? %>
								<%= link_to @job.developer.name,
                      developer_path(@job.developer),
                      class: "text-busybee-700 underline decoration-busybee-200 underline-offset-2 hover:text-busybee-800" %>
							<% else %>
								Unassigned
							<% end %>
						</p>
					</div>

					<div>
						<p class="text-xs font-semibold uppercase tracking-wide text-busybee-400">Deadline</p>
						<p class="mt-1 text-sm text-busybee-700">
							<%= l(@job.deadline, format: :long) rescue @job.deadline %>
						</p>
					</div>
				</div>
			</div>

			<div class="rounded-2xl border border-white/60 bg-white/88 p-6 shadow-xl backdrop-blur">
				<h2 class="text-lg font-semibold text-busybee-900">Actions</h2>

				<div class="mt-5 flex flex-col gap-3">
					<%= link_to "Back to jobs",
                jobs_path,
                class: "inline-flex items-center justify-center rounded-md border border-busybee-300 bg-white px-4 py-2 text-sm font-medium text-busybee-700 hover:bg-busybee-50" %>

					<% if logged_in? && current_user.client.present? && current_user.client == @job.client %>
						<%= link_to "Write feedback",
                new_job_feedback_path(@job),
                class: "inline-flex items-center justify-center rounded-md border border-busybee-300 bg-white px-4 py-2 text-sm font-medium text-busybee-700 hover:bg-busybee-50" %>
					<% end %>

					<% if logged_in? && current_user.client.present? && @job.editable_by_client?(current_user) %>
						<%= link_to "Edit job",
                edit_job_path(@job),
                class: "inline-flex items-center justify-center rounded-md bg-busybee-500 px-4 py-2 text-sm font-medium text-white hover:bg-busybee-600" %>

						<%= button_to "Delete job",
                  job_path(@job),
                  method: :delete,
                  data: { confirm: "Are you sure you want to delete this job?" },
                  class: "inline-flex items-center justify-center rounded-md bg-rose-600 px-4 py-2 text-sm font-medium text-white hover:bg-rose-700" %>
					<% end %>
				</div>
			</div>
		</div>
	</section>
</div>