<div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
	<section class="lg:col-span-1">
		<div class="rounded-2xl border border-white/60 bg-white/88 p-6 shadow-xl backdrop-blur">
			<div class="flex items-start gap-4">
				<div class="flex h-12 w-12 items-center justify-center rounded-full bg-busybee-100 text-lg font-semibold text-busybee-700">
					<%= @client.name.first.upcase %>
				</div>

				<div>
					<h1 class="text-2xl font-bold tracking-tight text-busybee-900"><%= @client.name %></h1>
					<p class="mt-1 text-sm text-busybee-500"><%= @client.email %></p>
				</div>
			</div>

			<div class="mt-6">
				<p class="text-xs font-semibold uppercase tracking-wide text-busybee-400">Feedback written</p>
				<p class="mt-2 text-sm text-busybee-700">
					<%= pluralize(@client.authored_feedbacks.count, "review") %>
				</p>
			</div>

			<div class="mt-6">
				<p class="text-xs font-semibold uppercase tracking-wide text-busybee-400">Jobs posted</p>
				<p class="mt-2 text-sm text-busybee-700">
					<%= pluralize(@client.jobs.count, "job") %>
				</p>
			</div>

			<% if logged_in? && current_user == @client.user %>
				<div class="mt-8">
					<%= link_to user_path(current_user),
              class: "inline-flex items-center gap-2 rounded-md border border-busybee-200 bg-white px-3 py-2 text-sm font-medium text-busybee-700 hover:bg-busybee-50" do %>
						← Back to My Profile
					<% end %>
				</div>
			<% end %>
		</div>
	</section>

	<section class="lg:col-span-2">
		<div class="rounded-2xl border border-white/60 bg-white/88 p-6 shadow-xl backdrop-blur">
			<div class="mb-6">
				<h2 class="text-xl font-semibold text-busybee-900">Feedback written</h2>
				<p class="mt-1 text-sm text-busybee-500">Reviews this client has written for developers.</p>
			</div>

			<% if @feedbacks.any? %>
				<div class="space-y-4">
					<% @feedbacks.each do |feedback| %>
						<article class="rounded-xl border border-busybee-200/80 bg-white/80 p-4 shadow-sm">
							<div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
								<div>
									<p class="font-semibold text-busybee-900">
										For developer: <%= feedback.developer&.name || "Unassigned" %>
									</p>

									<p class="mt-1 text-sm text-busybee-500">
										Job:
										<%= link_to feedback.job.title,
                          job_path(feedback.job),
                          class: "text-busybee-700 underline decoration-busybee-200 underline-offset-2 hover:text-busybee-800" %>
									</p>
								</div>

								<div class="text-busybee-600">
									<%= "★" * feedback.rating %><%= "☆" * (5 - feedback.rating) %>
								</div>
							</div>

							<p class="mt-3 text-sm leading-6 text-busybee-700">
								<%= feedback.comment.presence || "No comment provided." %>
							</p>

							<% if logged_in? && feedback.editable_by_client?(current_user) %>
								<div class="mt-3">
									<%= link_to "Edit feedback",
                      edit_feedback_path(feedback),
                      class: "text-sm font-medium text-busybee-700 hover:underline" %>
								</div>
							<% end %>
						</article>
					<% end %>
				</div>
			<% else %>
				<p class="text-sm text-busybee-500">This client has not written any feedback yet.</p>
			<% end %>
		</div>
	</section>
</div>