<div class="mb-8 rounded-2xl border border-white/60 bg-white/80 p-6 shadow-lg backdrop-blur">
	<h1 class="text-3xl font-bold tracking-tight text-busybee-900">Clients</h1>
	<p class="mt-1 text-sm text-busybee-600">
		Browse client profiles and the feedback they have written.
	</p>
</div>

<% if @clients.any? %>
	<div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
		<% @clients.each do |client| %>
			<%= link_to client_path(client),
          class: "group block rounded-2xl border border-white/60 bg-white/88 p-6 shadow-xl backdrop-blur transition hover:-translate-y-1 hover:shadow-2xl" do %>

				<article>
					<div class="flex items-start justify-between gap-4">
						<div class="flex items-start gap-3">
							<div class="flex h-10 w-10 items-center justify-center rounded-full bg-busybee-100 font-semibold text-busybee-700">
								<%= client.name.first.upcase %>
							</div>

							<div>
								<h2 class="text-xl font-semibold text-busybee-900 group-hover:text-busybee-700">
									<%= client.name %>
								</h2>

								<p class="mt-1 text-sm text-busybee-500">
									<%= client.email %>
								</p>
							</div>
						</div>

						<span class="rounded-full bg-busybee-100 px-3 py-1 text-xs font-semibold text-busybee-800">
							Client
						</span>
					</div>

					<div class="mt-5">
						<p class="text-xs font-semibold uppercase tracking-wide text-busybee-400">
							Feedback written
						</p>

						<p class="mt-2 text-sm text-busybee-700">
							<%= pluralize(client.authored_feedbacks.count, "review") %>
						</p>
					</div>

					<div class="mt-5">
						<p class="text-xs font-semibold uppercase tracking-wide text-busybee-400">
							Jobs posted
						</p>

						<p class="mt-2 text-sm text-busybee-700">
							<%= pluralize(client.jobs.count, "job") %>
						</p>
					</div>

					<div class="mt-6 flex items-center justify-end">
						<span class="text-sm font-medium text-busybee-600 group-hover:underline">
							View profile →
						</span>
					</div>
				</article>

			<% end %>
		<% end %>
	</div>
<% else %>
	<div class="rounded-2xl border border-white/60 bg-white/88 p-6 text-sm text-busybee-500 shadow-xl backdrop-blur">
		No clients found.
	</div>
<% end %>