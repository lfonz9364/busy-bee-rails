<div class="space-y-8">
	<div class="rounded-2xl border border-white/60 bg-white/80 p-6 shadow-lg backdrop-blur">
		<h1 class="text-3xl font-bold tracking-tight text-busybee-900">My Applications</h1>
		<p class="mt-1 text-sm text-busybee-600">
			Track your pending, in progress, declined, and completed work.
		</p>
	</div>

	<section class="rounded-2xl border border-white/60 bg-white/88 p-6 shadow-xl backdrop-blur">
		<h2 class="text-xl font-semibold text-busybee-900">Pending Applications</h2>

		<% if @pending_applications.any? %>
			<div class="mt-4 space-y-4">
				<% @pending_applications.each do |application| %>
					<div class="rounded-xl border border-busybee-200/80 bg-white/80 p-4 shadow-sm">
						<div class="flex items-start justify-between gap-4">
							<div>
								<p class="font-semibold text-busybee-900">
									<%= link_to application.job.title, job_path(application.job), class: "text-busybee-700 hover:underline" %>
								</p>
								<p class="mt-1 text-sm text-busybee-500">
									Client: <%= application.job.client.name %>
								</p>
								<p class="mt-2 text-sm text-busybee-700">
									<%= application.message.presence || "No message provided." %>
								</p>
							</div>

							<span class="rounded-full border border-busybee-200 bg-busybee-50 px-3 py-1 text-xs font-semibold text-busybee-700">
								Pending
							</span>
						</div>
					</div>
				<% end %>
			</div>
		<% else %>
			<p class="mt-4 text-sm text-busybee-500">No pending applications.</p>
		<% end %>
	</section>

	<section class="rounded-2xl border border-white/60 bg-white/88 p-6 shadow-xl backdrop-blur">
		<h2 class="text-xl font-semibold text-busybee-900">In Progress Jobs</h2>

		<% if @in_progress_jobs.any? %>
			<div class="mt-4 space-y-4">
				<% @in_progress_jobs.each do |job| %>
					<div class="rounded-xl border border-busybee-200/80 bg-white/80 p-4 shadow-sm">
						<p class="font-semibold text-busybee-900">
							<%= link_to job.title, job_path(job), class: "text-busybee-700 hover:underline" %>
						</p>
						<p class="mt-1 text-sm text-busybee-500">
							Client: <%= job.client.name %>
						</p>
						<p class="mt-2 text-sm text-busybee-700">
							Reward: $<%= job.reward %>
						</p>
					</div>
				<% end %>
			</div>
		<% else %>
			<p class="mt-4 text-sm text-busybee-500">No jobs currently in progress.</p>
		<% end %>
	</section>

	<section class="rounded-2xl border border-white/60 bg-white/88 p-6 shadow-xl backdrop-blur">
		<h2 class="text-xl font-semibold text-busybee-900">Declined Applications</h2>

		<% if @declined_applications.any? %>
			<div class="mt-4 space-y-4">
				<% @declined_applications.each do |application| %>
					<div class="rounded-xl border border-busybee-200/80 bg-white/80 p-4 shadow-sm">
						<div class="flex items-start justify-between gap-4">
							<div>
								<p class="font-semibold text-busybee-900">
									<%= link_to application.job.title, job_path(application.job), class: "text-busybee-700 hover:underline" %>
								</p>
								<p class="mt-1 text-sm text-busybee-500">
									Client: <%= application.job.client.name %>
								</p>
							</div>

							<span class="rounded-full border border-rose-200 bg-rose-50 px-3 py-1 text-xs font-semibold text-rose-700">
								<%= application.status.humanize %>
							</span>
						</div>
					</div>
				<% end %>
			</div>
		<% else %>
			<p class="mt-4 text-sm text-busybee-500">No declined applications.</p>
		<% end %>
	</section>

	<section class="rounded-2xl border border-white/60 bg-white/88 p-6 shadow-xl backdrop-blur">
		<h2 class="text-xl font-semibold text-busybee-900">Completed Jobs</h2>

		<% if @completed_jobs.any? %>
			<div class="mt-4 space-y-4">
				<% @completed_jobs.each do |job| %>
					<div class="rounded-xl border border-busybee-200/80 bg-white/80 p-4 shadow-sm">
						<p class="font-semibold text-busybee-900">
							<%= link_to job.title, job_path(job), class: "text-busybee-700 hover:underline" %>
						</p>
						<p class="mt-1 text-sm text-busybee-500">
							Client: <%= job.client.name %>
						</p>
						<p class="mt-2 text-sm text-busybee-700">
							Reward: $<%= job.reward %>
						</p>
					</div>
				<% end %>
			</div>
		<% else %>
			<p class="mt-4 text-sm text-busybee-500">No completed jobs yet.</p>
		<% end %>
	</section>
</div>