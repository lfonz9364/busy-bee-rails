<div class="mb-8 rounded-2xl border border-white/60 bg-white/80 p-6 shadow-lg backdrop-blur">
	<h1 class="text-3xl font-bold tracking-tight text-busybee-900">Users</h1>
	<p class="mt-1 text-sm text-busybee-600">
		Admin-only user management.
	</p>
</div>

<% if @users.any? %>
	<div class="space-y-4">
		<% @users.each do |user| %>
			<div class="flex items-center justify-between rounded-2xl border border-white/60 bg-white/88 p-5 shadow-xl backdrop-blur">
				<div>
					<h2 class="text-lg font-semibold text-busybee-900"><%= user.name %></h2>
					<p class="text-sm text-busybee-500"><%= user.email %></p>
					<p class="mt-1 text-xs text-busybee-400">
						<%= user.admin? ? "Admin" : "Standard user" %>
					</p>
				</div>

				<div class="flex items-center gap-3">
					<%= link_to "View profile",
                user_path(user),
                class: "rounded-md border border-busybee-300 bg-white px-4 py-2 text-sm font-medium text-busybee-700 hover:bg-busybee-50" %>

					<% unless user.admin? %>
						<%= button_to "Make admin",
                  make_admin_user_path(user),
                  method: :patch,
                  data: { confirm: "Are you sure you want to grant admin access to #{user.name}?" },
                  class: "rounded-md bg-busybee-500 px-4 py-2 text-sm font-medium text-white hover:bg-busybee-600" %>
					<% end %>
				</div>
			</div>
		<% end %>
	</div>
<% else %>
	<div class="rounded-2xl border border-white/60 bg-white/88 p-6 text-sm text-busybee-500 shadow-xl backdrop-blur">
		No users found.
	</div>
<% end %>