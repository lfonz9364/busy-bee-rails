<h1>Login</h1>
<%= form_with url: login_path, method: :post, local: true do |form| %>
  <div class="field">
    <%= form.label :email %><br>
    <%= form.email_field :email, required: true %>
  </div>
  <div class="field">
    <%= form.label :password %><br>
    <%= form.password_field :password, required: true %>
  </div>
  <div class="actions">
    <%= form.submit "Log in" %>
  </div>
<% end %>