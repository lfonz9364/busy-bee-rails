<div class="flex min-h-[75vh] items-center justify-center">
	<div class="w-full max-w-md rounded-2xl border border-white/60 bg-white/90 p-8 shadow-2xl backdrop-blur">
		<div class="mb-6 text-center">
			<h1 class="text-2xl font-bold tracking-tight text-busybee-900">Welcome back</h1>
			<p class="mt-2 text-sm text-busybee-600">Sign in to your Busy Bee account</p>
		</div>

		<%= form_with url: login_path, method: :post, local: true, class: "space-y-5" do |form| %>
			<div>
				<%= form.label :email, class: "mb-1 block text-sm font-medium text-busybee-700" %>
				<%= form.email_field :email,
              required: true,
              class: "block w-full rounded-lg border border-busybee-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-busybee-500 focus:outline-none focus:ring-2 focus:ring-busybee-200" %>
			</div>

			<div>
				<%= form.label :password, class: "mb-1 block text-sm font-medium text-busybee-700" %>
				<%= form.password_field :password,
              required: true,
              class: "block w-full rounded-lg border border-busybee-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-busybee-500 focus:outline-none focus:ring-2 focus:ring-busybee-200" %>
			</div>

			<div class="pt-2">
				<%= form.submit "Login",
              class: "inline-flex w-full items-center justify-center rounded-lg bg-busybee-500 px-4 py-2.5 text-sm font-medium text-white hover:bg-busybee-600" %>
			</div>
		<% end %>

		<p class="mt-4 text-center text-sm text-busybee-500">
			<%= link_to "Forgot your password?", forgot_password_path, class: "text-busybee-600 hover:underline" %>
		</p>
	</div>
</div>