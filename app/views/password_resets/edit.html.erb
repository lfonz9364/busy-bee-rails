<div class="flex min-h-[70vh] items-center justify-center">
	<div class="w-full max-w-md rounded-2xl border border-white/60 bg-white/90 p-8 shadow-2xl backdrop-blur">
		<div class="mb-6 text-center">
			<h1 class="text-2xl font-bold tracking-tight text-busybee-900">Reset Password</h1>
			<p class="mt-2 text-sm text-busybee-600">
				Enter your new password below.
			</p>
		</div>

		<% if @user.errors.any? %>
			<div class="mb-4 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800">
				<ul class="list-disc pl-5">
					<% @user.errors.full_messages.each do |message| %>
						<li><%= message %></li>
					<% end %>
				</ul>
			</div>
		<% end %>

		<%= form_with model: @user, url: reset_password_path(params[:token]), method: :patch, local: true, class: "space-y-5" do |f| %>
			<div>
				<%= f.label :password, class: "mb-1 block text-sm font-medium text-busybee-700" %>
				<%= f.password_field :password,
              required: true,
              class: "block w-full rounded-lg border border-busybee-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-busybee-500 focus:outline-none focus:ring-2 focus:ring-busybee-200" %>
			</div>

			<div>
				<%= f.label :password_confirmation, class: "mb-1 block text-sm font-medium text-busybee-700" %>
				<%= f.password_field :password_confirmation,
              required: true,
              class: "block w-full rounded-lg border border-busybee-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-busybee-500 focus:outline-none focus:ring-2 focus:ring-busybee-200" %>
			</div>

			<div class="pt-2">
				<%= f.submit "Reset password",
              class: "inline-flex w-full items-center justify-center rounded-lg bg-busybee-500 px-4 py-2.5 text-sm font-medium text-white hover:bg-busybee-600" %>
			</div>
		<% end %>
	</div>
</div>