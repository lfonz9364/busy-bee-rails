<div class="flex min-h-[70vh] items-center justify-center">
	<div class="w-full max-w-lg rounded-2xl border border-white/60 bg-white/90 p-8 shadow-2xl backdrop-blur">

		<h1 class="text-2xl font-bold text-busybee-900 text-center mb-6">
			Create your Busy Bee account
		</h1>

		<% if @user.errors.any? %>
			<div class="mb-4 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800">
				<p class="mb-2 font-semibold">
					<%= pluralize(@user.errors.count, "error") %> prevented signup:
				</p>
				<ul class="list-disc pl-5">
					<% @user.errors.full_messages.each do |message| %>
						<li><%= message %></li>
					<% end %>
				</ul>
			</div>
		<% end %>

		<%= form_with model: @user, url: signup_path, local: true, class: "space-y-4 text-busybee-700" do |f| %>

			<div>
				<%= f.label :name, class: "text-sm font-medium text-busybee-700" %>
				<%= f.text_field :name, required: true,
              class: "mt-1 w-full rounded-md border border-busybee-300 px-3 py-2" %>
			</div>

			<div>
				<%= f.label :email, class: "text-sm font-medium text-busybee-700" %>
				<%= f.email_field :email, required: true,
              class: "mt-1 w-full rounded-md border border-busybee-300 px-3 py-2" %>
			</div>

			<div>
				<%= f.label :abn, class: "text-sm font-medium text-busybee-700" %>
				<%= f.text_field :abn,
              maxlength: 14,
              inputmode: "numeric",
              placeholder: "12 345 678 901", 
              required: true,
              data: { abn_format: true },
              class: "mt-1 w-full rounded-md border border-busybee-300 px-3 py-2" %>
			</div>

			<div>
				<%= f.label :contact_person, class: "text-sm font-medium text-busybee-700" %>
				<%= f.text_field :contact_person,
        class: "mt-1 w-full rounded-md border border-busybee-300 px-3 py-2" %>
			</div>

			<div>
				<%= f.label :password, class: "text-sm font-medium text-busybee-700" %>
				<%= f.password_field :password, required: true,
              class: "mt-1 w-full rounded-md border border-busybee-300 px-3 py-2" %>
			</div>

			<div>
				<%= f.label :password_confirmation, class: "text-sm font-medium text-busybee-700" %>
				<%= f.password_field :password_confirmation, required: true,
              class: "mt-1 w-full rounded-md border border-busybee-300 px-3 py-2" %>
			</div>

			<div>
				<%= f.label :role, "Register as", class: "text-sm font-medium text-busybee-700" %>
				<div class="relative">
					<%= f.select :role,
              [["Client", "client"], ["Developer", "developer"]],
              {},
              class: "mt-1 w-full rounded-md border border-busybee-300 px-3 py-2 pr-10 appearance-none 
                      bg-white focus:outline-none focus:ring-2 focus:ring-busybee-500 focus:border-busybee-500",
              data: { role_toggle: true } %>

					<div class="pointer-events-none absolute inset-y-0 right-4 top-1 flex items-center text-busybee-500 ">
						▼
					</div>
				</div>
			</div>

			<div data-skillset-wrapper class="<%= @user.role == 'developer' ? '' : 'hidden' %>">
				<%= f.label :skillset, class: "text-sm font-medium text-busybee-700" %>
				<%= f.text_field :skillset,
        class: "mt-1 w-full rounded-md border border-busybee-300 px-3 py-2",
        placeholder: "e.g. Ruby on Rails, React, TypeScript" %>
			</div>

			<div>
				<%= f.label :address, class: "text-sm font-medium text-busybee-700" %>
				<%= f.text_field :address,
              class: "mt-1 w-full rounded-md border border-busybee-300 px-3 py-2" %>
			</div>

			<div class="grid grid-cols-2 gap-3">
				<div>
					<%= f.label :suburb, class: "text-sm font-medium text-busybee-700" %>
					<%= f.text_field :suburb,
                class: "mt-1 w-full rounded-md border border-busybee-300 px-3 py-2" %>
				</div>

				<div>
					<%= f.label :postcode, class: "text-sm font-medium text-busybee-700" %>
					<%= f.text_field :postcode,
                class: "mt-1 w-full rounded-md border border-busybee-300 px-3 py-2" %>
				</div>
			</div>

			<div class="grid grid-cols-2 gap-3">
				<div>
					<%= f.label :state, class: "text-sm font-medium text-busybee-700" %>
					<%= f.text_field :state,
        class: "mt-1 w-full rounded-md border border-busybee-300 px-3 py-2" %>
				</div>

				<div>
					<%= f.label :country, class: "text-sm font-medium text-busybee-700" %>
					<%= f.text_field :country,
              class: "mt-1 w-full rounded-md border border-busybee-300 px-3 py-2" %>
				</div>
			</div>

			<div class="pt-3">
				<%= f.submit "Create account",
              class: "w-full rounded-md bg-busybee-500 px-4 py-2 font-medium text-white hover:bg-busybee-600",
              data: {
                loading_text: "Creating account...",
                disable_with: "Creating account..."  
              } %>
			</div>

		<% end %>

		<p class="mt-6 text-center text-sm text-busybee-800">
			Already have an account?
			<%= link_to "Login", login_path, class: "text-busybee-700 hover:underline" %>
		</p>

	</div>
</div>